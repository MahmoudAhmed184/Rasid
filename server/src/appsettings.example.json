{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "Rasid.Server.Services.JobPollingWorker": "Information",
            "Rasid.Server.Services.ScrapeCycleRunner": "Information"
        }
    },
    "AllowedHosts": "*",
    "Urls": "http://localhost:5000;https://localhost:5001",
    "JobScraper": {
        "InitialDelaySeconds": 5,
        "CheckIntervalSeconds": 60,
        "MaxSeenJobs": 500,
        "MaxConcurrentEnrichmentsPerPlatform": 4
    },
    "Cors": {
        "Mode": "AllowAll",
        "AllowedOrigins": []
    },
    "AdminToken": "change-me-in-production"
}

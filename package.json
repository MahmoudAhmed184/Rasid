{
    "name": "frelancia",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "description": "Cross-browser Manifest V3 build pipeline for the Rasid (راصد) WebExtension",
    "engines": {
        "node": ">=20.19.0"
    },
    "scripts": {
        "postinstall": "wxt prepare",
        "dev:chrome": "wxt -b chrome --mv3",
        "dev:firefox": "wxt -b firefox --mv3",
        "build": "npm run build:chrome && npm run build:firefox",
        "build:chrome": "wxt build -b chrome --mv3",
        "build:firefox": "wxt build -b firefox --mv3",
        "zip:chrome": "wxt zip -b chrome --mv3",
        "zip:firefox": "wxt zip -b firefox --mv3",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "npm run lint:ts && eslint .",
        "lint:fix": "eslint . --fix",
        "lint:ts": "tsc -p tsconfig.json --noEmit --noUnusedLocals --noUnusedParameters",
        "test": "npm run test:typecheck && npm run test:unit && npm run test:integration",
        "test:typecheck": "tsc -p tests/tsconfig.json --noEmit",
        "test:unit": "vitest run --config vitest.config.ts tests/src/entities tests/src/shared tests/src/platforms",
        "test:integration": "vitest run --config vitest.config.ts tests/src/app tests/src/features tests/entrypoints",
        "test:e2e": "npm run test:e2e:chrome && npm run test:e2e:firefox",
        "test:e2e:chrome": "playwright test --config playwright.config.ts --project=chromium-extension",
        "test:e2e:firefox": "npm run build:firefox && npm run lint:firefox && RASID_RUN_FIREFOX_BROWSER_SMOKE=1 vitest run --config vitest.config.ts tests/e2e/firefox && playwright test --config playwright.config.ts --project=firefox-browser",
        "test:coverage": "vitest run --config vitest.config.ts --coverage",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "lint:firefox": "web-ext lint --source-dir dist/firefox-mv3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.60.0",
        "@vitest/coverage-v8": "^4.1.7",
        "eslint": "^10.4.0",
        "globals": "^17.6.0",
        "prettier": "^3.8.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.0",
        "vitest": "^4.1.7",
        "web-ext": "^10.3.0",
        "wxt": "^0.20.26"
    },
    "dependencies": {
        "@microsoft/signalr": "^10.0.0",
        "@rolldown/binding-win32-x64-msvc": "^1.0.2"
    },
    "overrides": {
        "node-notifier": {
            "uuid": "^11.1.1"
        },
        "encoding-sniffer": "1.0.2",
        "web-ext-run": {
            "tmp": "0.2.7"
        }
    }
}
